@article{chen2020ChemicalProduction,
  title = {Chemical {{Production}} from {{Methanol Using Natural}} and {{Synthetic Methylotrophs}}},
  author = {Chen, Arvin Y. and Lan, Ethan I.},
  year = 2020,
  month = jun,
  journal = {Biotechnology Journal},
