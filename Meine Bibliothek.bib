  author = {Jones, J. Andrew and Vernacchio, Victoria R. and Lachance, Daniel M. and Lebovich, Matthew and Fu, Li and Shirke, Abhijit N. and Schultz, Victor L. and Cress, Brady and Linhardt, Robert J. and Koffas, Mattheos A. G.},
  year = 2015,
