  title = {Engineering a Synthetic Energy-Efficient Formaldehyde Assimilation Cycle in {{Escherichia}} Coli},
  author = {Wu, Tong and {G{\'o}mez-Coronado}, Paul A. and Kubis, Armin and Lindner, Steffen N. and Marli{\`e}re, Philippe and Erb, Tobias J. and {Bar-Even}, Arren and He, Hai},
  year = 2023,
