@article{orsi2023SynergisticInvestigation,
  title = {Synergistic Investigation of Natural and Synthetic {{C1-trophic}} Microorganisms to Foster a Circular Carbon Economy},
  author = {Orsi, Enrico and Nikel, Pablo Ivan and Nielsen, Lars Keld and Donati, Stefano},
