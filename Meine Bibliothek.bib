@article{denby2016MechanismFormaldehydesensing,
  title = {The Mechanism of a Formaldehyde-Sensing Transcriptional Regulator},
  author = {Denby, Katie J. and Iwig, Jeffrey and Bisson, Claudine and Westwood, Jodie and Rolfe, Matthew D. and Sedelnikova, Svetlana E. and Higgins, Khadine and Maroney, Michael J. and Baker, Patrick J. and Chivers, Peter T. and Green, Jeffrey},
  year = 2016,
  month = dec,
  journal = {Scientific Reports},
  volume = {6},
  number = {1},
  pages = {38879},
  issn = {2045-2322},
  doi = {10.1038/srep38879},
  urldate = {2026-05-29},
  abstract = {Abstract                            Most organisms are exposed to the genotoxic chemical formaldehyde, either from endogenous or environmental sources. Therefore, biology has evolved systems to perceive and detoxify formaldehyde. The               frmRA(B)               operon that is present in many bacteria represents one such system. The FrmR protein is a transcriptional repressor that is specifically inactivated in the presence of formaldehyde, permitting expression of the formaldehyde detoxification machinery (FrmA and FrmB, when the latter is present). The X-ray structure of the formaldehyde-treated               Escherichia coli               FrmR (               Ec               FrmR) protein reveals the formation of methylene bridges that link adjacent Pro2 and Cys35 residues in the               Ec               FrmR tetramer. Methylene bridge formation has profound effects on the pattern of surface charge of               Ec               FrmR and combined with biochemical/biophysical data suggests a mechanistic model for formaldehyde-sensing and derepression of               frmRA(B)               expression in numerous bacterial species.},
  langid = {english},
  keywords = {notion},
  file = {C:\Users\canoscaliskan\Zotero\storage\XBMJHDPT\Denby et al. - 2016 - The mechanism of a formaldehyde-sensing transcriptional regulator.pdf}
}

